{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SexyNotes",
  "version": "0.1.0",
  "identifier": "com.tauri.dev",
  "build": {
    "beforeDevCommand": "turbo run dev --filter=web",
    "beforeBuildCommand": "turbo run build --filter=web",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../web/out"
  },
  "app": {
    "windows": [
      {
        "title": "SexyNotes",
        "width": 1400,
        "height": 900,
        "decorations": false,
        "transparent": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
