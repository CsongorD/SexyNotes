{
  "extends": "@repo/typescript-config/nextjs.json",
  "compilerOptions": {

    "baseUrl": ".",                     // or "./" if not already present
    "paths": {
      "@/*": ["./*"]                    // points to root of apps/web
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "strictNullChecks": true
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "next-env.d.ts",
    "next.config.js",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
